SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
GEMINI_API_KEY=your-gemini-api-key

# Comma-separated allowed origins for frontend (or * for quick testing)
BACKEND_CORS_ORIGINS=https://your-vercel-app.vercel.app,http://localhost:3000

# Optional: allow all Vercel preview deployments
BACKEND_CORS_ALLOW_VERCEL_PREVIEWS=true

# Optional explicit regex override (if set, takes priority)
# BACKEND_CORS_ORIGIN_REGEX=https://.*\.vercel\.app
